# Reglex / Mississippi SoS Legal RAG PoC
# Copy this file to .env and fill in real values for local development.
# Never commit a populated .env file. All values below are placeholders.

# ── AWS ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile-name
AWS_ACCOUNT_ID=123456789012

# ── OpenSearch (vector index) ────────────────────────────────────────
# Phase 1 (Mississippi pilot) index
OPENSEARCH_ENDPOINT=https://search-<your-domain>.<region>.es.amazonaws.com
OPENSEARCH_INDEX_PHASE1=ms-legal-abstracts
# Phase 2 (multi-state) index
OPENSEARCH_INDEX_PHASE2=multistate-legal

# ── Amazon Bedrock (LLM + embeddings) ────────────────────────────────
BEDROCK_LLM_MODEL=us.anthropic.claude-sonnet-4-6
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── DynamoDB (async job tracking for the lambda handler) ─────────────
JOBS_TABLE=ms-sos-query-jobs

# ── S3 (source documents) ────────────────────────────────────────────
S3_BUCKET=your-source-bucket
S3_PREFIX=source-documents

# ── Lambda + API Gateway (deployment metadata) ───────────────────────
LAMBDA_FUNCTION_NAME=ms-sos-legal-v2
API_ID=your-api-gateway-id

# ── Frontend (Vite) ──────────────────────────────────────────────────
# Used by src/frontend at build time
VITE_API_ENDPOINT=https://<API_ID>.execute-api.us-east-1.amazonaws.com/prod
